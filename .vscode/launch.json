{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug: calculator (CMake Tools)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": ["{\"operation\": \"add\", \"operands\": [2, 3]}"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [
                {
                    "name": "PATH",
                    "value": "${env:PATH}:${command:cmake.getLaunchTargetDirectory}"
                }
            ],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug: calculator",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/calculator",
            "args": ["{\"operation\": \"add\", \"operands\": [2, 3]}"],
            "preLaunchTask": "Build: Debug",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Release: calculator",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build_release/calculator",
            "args": ["{\"operation\": \"add\", \"operands\": [2, 3]}"],
            "preLaunchTask": "Build: Release",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug: all tests",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/tests/calculator_tests",
            "args": [],
            "preLaunchTask": "Build: Debug",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "Debug: single test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/tests/calculator_tests",
            "args": ["--gtest_filter=CalculatorTest.Add"],
            "preLaunchTask": "Build: Debug",
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
